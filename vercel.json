{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/claude.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/app/(.*)", "destination": "/index.html" },
    { "source": "/app",     "destination": "/index.html" },
    { "source": "/",        "destination": "/landing.html" }
  ]
}
